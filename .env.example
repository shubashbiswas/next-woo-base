# ═══════════════════════════════════════════════════════════
#  Environment Variables Template
#  Copy this file to .env.local and fill in your values:
#    cp .env.example .env.local
# ═══════════════════════════════════════════════════════════

# ─── WordPress (Required for blog/content features) ────────
WORDPRESS_URL="https://your-wordpress-domain.com"
WORDPRESS_HOSTNAME="your-wordpress-domain.com"
WORDPRESS_WEBHOOK_SECRET="your-secret-key-here"
# Shared secret between WordPress plugin and Next.js revalidation
# endpoint. Must match exactly what's configured in:
#   WordPress Admin → Settings → Next.js Revalidation
#
# Generate a strong secret:
#   Windows (PowerShell):  [System.Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
#   Linux/macOS:           openssl rand -base64 32
#   Online:                https://generate-secret.now.sh/32

# ─── WooCommerce (Required for shop features) ──────────────
# Get these from: WordPress Admin → WooCommerce → Settings → Advanced → REST API
WC_CONSUMER_KEY="ck_your_consumer_key_here"
WC_CONSUMER_SECRET="cs_your_consumer_secret_here"

# ─── Site URL (Required for CSRF protection and canonical URLs) ─
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
NEXT_WORDPRESS_SITE_URL="http://localhost:3000"
# Used for:
#   - CSRF origin validation on checkout endpoint (/api/checkout)
#   - Canonical URL generation
#   - Open Graph / Twitter card metadata
# This must be the full public URL of your Next.js frontend.

# ─── Stripe (Optional — for headless checkout without redirect) ─
# Get your secret key from: https://dashboard.stripe.com/apikeys
# When set, the checkout endpoint creates a PaymentIntent so the
# frontend can collect payment via Stripe Elements without redirecting
# the user to the external WooCommerce checkout page.
# STRIPE_SECRET_KEY="sk_live_..."

# ─── Sentry (Optional — for error monitoring) ──────────────
# Get your DSN from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
# NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@sentry.io/your-project-id"
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
# SENTRY_AUTH_TOKEN="your-auth-token"

# ─── Optional Settings ─────────────────────────────────────
ISR_CACHE_TTL=30
# Accept self-signed certificates from local WordPress (dev only)
# Remove this in production
NODE_TLS_REJECT_UNAUTHORIZED=0
# NEXT_PUBLIC_ANALYTICS_PROVIDER="plausible"
# NEXT_PUBLIC_ANALYTICS_SRC="https://plausible.io/js/script.js"
# NEXT_PUBLIC_ANALYTICS_DOMAIN="yourdomain.com"
# NEXT_PUBLIC_ANALYTICS_SITE_ID=""
# NEXT_PUBLIC_ANALYTICS_MEASUREMENT_ID="G-XXXXXXXX"

# ═══════════════════════════════════════════════════════════
#  Local Development Example (Laragon)
#  Uncomment and adjust for your local setup:
# ═══════════════════════════════════════════════════════════

# WORDPRESS_URL="http://localhost:8000"
# WORDPRESS_HOSTNAME="localhost"
# WORDPRESS_WEBHOOK_SECRET="dev-secret-do-not-use-in-prod"
# WC_CONSUMER_KEY="ck_your_local_key"
# WC_CONSUMER_SECRET="cs_your_local_secret"
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# ISR_CACHE_TTL=30